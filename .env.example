# HTTP (REST)
# The CHE1 Dashboard BFF also defaults to :8080, so the Dashboard's
# docker-compose runs this Worker on :8081. Use the same locally.
HTTP_LISTEN_ADDR=:8081

# gRPC
GRPC_LISTEN_ADDR=:9090

# WebSocket hub (frontend)
WS_LISTEN_ADDR=:8090
WS_PATH=/ws

# Postgres
DATABASE_URL=postgres://user:pass@localhost:5432/che1?sslmode=disable
DATABASE_MAX_CONNS=10

# Redis (Pub/Sub + cache)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CHANNEL=worker.events

# External API (example third-party integration)
EXTERNAL_BASE_URL=https://api.example.com
EXTERNAL_API_KEY=changeme
EXTERNAL_TIMEOUT_SECONDS=10

# CHE1 Dashboard integration — https://github.com/CHE1-Bot/Dashboard
# DASHBOARD_BASE_URL enables outbound calls from the Worker into the Dashboard
# BFF (leave empty to disable).
DASHBOARD_BASE_URL=
DASHBOARD_API_KEY=
DASHBOARD_TIMEOUT_SECONDS=10
# Comma-separated origins allowed for CORS on REST and for browser WebSocket
# upgrades. Default covers the Dashboard frontend (Vite dev server) and BFF.
DASHBOARD_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Auth for inbound callers (Discord bot, Dashboard BFF, etc.).
# The Dashboard BFF must be configured with WORKER_API_KEY equal to this value.
INBOUND_API_KEY=changeme

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
